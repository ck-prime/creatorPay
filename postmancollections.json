{
"info": {
"name": "CreatorPay Gateway APIs",
"_postman_id": "creatorpay-gateway",
"description": "Full system APIs (Gateway + Auth + User Service)\n\nFlow:\n1. Signup → creates user in Auth + User Service\n2. Login → get tokens\n3. Use accessToken for protected routes\n4. Refresh → rotate tokens\n5. Logout → invalidate session",
"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
},
"variable": [
{ "key": "baseUrl", "value": "http://localhost:3000" },
{ "key": "accessToken", "value": "" },
{ "key": "refreshToken", "value": "" }
],
"item": [

```
{
  "name": "🏥 HEALTH CHECKS",
  "description": "Verify all services are running",
  "item": [
    {
      "name": "Gateway Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}"
      }
    },
    {
      "name": "Auth Service Health",
      "request": {
        "method": "GET",
        "url": "http://localhost:4001/health"
      }
    },
    {
      "name": "User Service Health",
      "request": {
        "method": "GET",
        "url": "http://localhost:4002/health"
      }
    }
  ]
},

{
  "name": "🔐 AUTH",
  "description": "Authentication & session management",
  "item": [

    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "description": "Creates a new user in Auth Service and syncs profile in User Service",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@yopmail.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/signup"
      }
    },

    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let json = pm.response.json();",
              "pm.collectionVariables.set(\"accessToken\", json.accessToken);",
              "pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
              "console.log(\"Tokens saved\");"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "description": "Authenticate user and receive access + refresh tokens",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@yopmail.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },

    {
      "name": "Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let json = pm.response.json();",
              "pm.collectionVariables.set(\"accessToken\", json.accessToken);",
              "pm.collectionVariables.set(\"refreshToken\", json.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "description": "Generate new access token using refresh token (token rotation supported)",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/refresh"
      }
    },

    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"accessToken\", \"\");",
              "pm.collectionVariables.set(\"refreshToken\", \"\");"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "description": "Invalidate refresh token and logout user",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/logout"
      }
    },

    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "description": "Send password reset email (rate limited)",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@yopmail.com\"\n}"
        },
        "url": "{{baseUrl}}/auth/forgot-password"
      }
    },

    {
      "name": "Reset Password",
      "request": {
        "method": "POST",
        "description": "Reset password using token received via email",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"RESET_TOKEN\",\n  \"newPassword\": \"newpassword123\"\n}"
        },
        "url": "{{baseUrl}}/auth/reset-password"
      }
    }
  ]
},

{
  "name": "👤 USER SERVICE",
  "description": "User profile APIs",
  "item": [
    {
      "name": "Get My Profile",
      "request": {
        "method": "GET",
        "description": "Fetch logged-in user profile using JWT (via gateway header forwarding)",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/user/me"
      }
    }
  ]
}
```

]
}
