						"{{baseUrl}}"
					],
					"path": [
						"auth",
						"refresh"
					]
				}
			},
			"response": []
		},
		{
			"name": "Logout",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.collectionVariables.set(\"accessToken\", \"\");",
							"pm.collectionVariables.set(\"refreshToken\", \"\");",
							"",
							"console.log(\"Tokens cleared after logout\");"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
